{
  "name": "i-am-not-a-robot",
  "version": "0.1.0",
  "description": "Hand an in-page CAPTCHA from your AI browser agent to a real human on their phone over CDP. They solve it with a finger and the agent resumes. MCP server, bring your own browser, no cloud lock-in. A human-in-the-loop relay, not a CAPTCHA solver.",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node src/selftest.js",
    "example:cdp": "node examples/captcha-demo.js",
    "selftest": "node src/selftest.js",
    "mcp": "node src/mcp-server.js",
    "mcp:e2e": "node test/mcp-e2e.js",
    "mcp:tunnel-e2e": "node test/tunnel-e2e.js"
  },
  "bin": {
    "i-am-not-a-robot": "src/mcp-server.js",
    "i-am-not-a-robot-mcp": "src/mcp-server.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cdp",
    "playwright",
    "puppeteer",
    "browser-use",
    "human-in-the-loop",
    "hitl",
    "ai-agent",
    "browser-agent",
    "captcha",
    "recaptcha",
    "hcaptcha",
    "turnstile",
    "screencast",
    "otp",
    "2fa",
    "approval",
    "ntfy",
    "automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Nicole Leung",
  "repository": { "type": "git", "url": "git+https://github.com/mcpware/i-am-not-a-robot.git" },
  "homepage": "https://github.com/mcpware/i-am-not-a-robot#readme",
  "bugs": "https://github.com/mcpware/i-am-not-a-robot/issues",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.21.0"
  },
  "peerDependenciesMeta": {}
}
