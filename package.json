{
  "name": "human-gate",
  "version": "0.1.0",
  "description": "The missing input() for headless agents. Pause any Playwright/Puppeteer agent at a step only a human can do (CAPTCHA, OTP, 2FA, approve/reject), push a screenshot to your phone, resume on your tap. Bring your own browser, no cloud lock-in.",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "example:cdp": "node examples/captcha-demo.js",
    "selftest": "node src/selftest.js",
    "mcp": "node src/mcp-server.js",
    "mcp:e2e": "node test/mcp-e2e.js",
    "mcp:tunnel-e2e": "node test/tunnel-e2e.js"
  },
  "bin": {
    "human-gate-mcp": "src/mcp-server.js"
  },
  "keywords": [
    "playwright",
    "puppeteer",
    "human-in-the-loop",
    "hitl",
    "ai-agent",
    "browser-agent",
    "captcha",
    "otp",
    "2fa",
    "approval",
    "ntfy",
    "automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.21.0"
  },
  "peerDependenciesMeta": {}
}
